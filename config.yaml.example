# OpenCode Processing Skills — Installer Configuration
#
# This file is OPTIONAL. Copy it to config.yaml to customize the installer.
# config.yaml is gitignored; your local choices never end up in the repo.
#
# Precedence (highest wins):
#   1. OPS_* environment variables  (runtime overrides, for tests/CI)
#   2. config.yaml                  (this file — persistent user config)
#   3. built-in defaults            (sensible auto-detect behavior)
#
# No external dependencies — install.sh uses only coreutils + grep + awk + sed.
#
# Install modes:
#   ./install.sh             global installation (uses targets below)
#   ./install.sh --project   local installation into ./.opencode/ (ignores targets)
#   ./install.sh --help      show usage


# ============================================================================
# Installation targets
# ============================================================================
# Which harnesses to install skills and agents into.
#
# Indentation: use 2-space indentation (not tabs). The installer's native
# YAML parser identifies target headers at depth 2 and fields at depth 4;
# other indentation styles will not parse.
#
# Each target has:
#   enabled: true | false | auto
#     - true  = always install
#     - false = never install
#     - auto  = install iff the target's `home` directory exists
#   home: filesystem path (supports ~)
#
# OpenCode is always required; `enabled` is fixed to true for that target.
# Codex installs only skills (no agents).
# Claude installs both skills and agents. Antigravity is served transitively
# via the bundled `anthropic.claude-code` extension, which reads from CLAUDE_HOME.
# Cursor installs workflow skills + orchestration layer (subagents, ops-orchestrator
# skills). See docs/installation.md and cursor/README.md. Use ./install.sh --project
# to install into ./.cursor/ per repo.
# Hermes installs only skills (like Codex), into the namespaced category directory
# HERMES_HOME/skills/processing/ — Hermes discovers SKILL.md files recursively
# and shows top-level directories as categories in its skills hub.

targets:
  opencode:
    enabled: true
    home: ~/.config/opencode

  codex:
    enabled: auto
    home: ~/.codex

  claude:
    enabled: auto
    home: ~/.claude

  cursor:
    enabled: auto
    home: ~/.cursor

  hermes:
    enabled: auto
    home: ~/.hermes


# ============================================================================
# Subagent models
# ============================================================================
# Set a specific model per agent. Agents not listed here (or with an empty
# value) keep the provider default. Format: <agent-name>: <provider/model-id>

delegate:
  model: openai/gpt-5.6-sol
  reasoningEffort: medium
doc-explorer:
  model: openai/gpt-5.6-sol
  reasoningEffort: medium
implementer:
  model: openai/gpt-5.6-sol
  reasoningEffort: medium
legacy-curator: openai/gpt-5.6-luna


# ============================================================================
# Additional delegate variants
# ============================================================================
# Each entry creates a model alias `delegate-<suffix>` from the one canonical
# delegate persona. Expertise and write boundaries come from loaded skills;
# variants change model capacity only:
#
#   - delegate-strong:  frontier model for independent reviews / hardest problems
#   - delegate-fast:    lightweight model for quick lookups
#   - delegate-codex:   code-specialized model for implementation analysis
#
# The primary agent can then target a specific variant:
#   "use delegate-strong for this review"
#   "delegate to delegate-fast for a quick lookup"
#
# Two syntaxes are supported:
#
#   Scalar (model only):
#     fast: openai/gpt-5.6-luna
#
#   Object (model + options for reasoning, temperature, etc.):
#     strong:
#       model: openai/gpt-5.6-sol
#       reasoningEffort: high

additional_delegates:
  strong:
    model: openai/gpt-5.6-sol
    reasoningEffort: xhigh
  codex: openai/gpt-5.3-codex            # If available, e.g. via API or Azure
  qwen: alibaba-eu/qwen3.7-max
  ds: deepseek/deepseek-v4-pro
  ds-flash: deepseek/deepseek-v4-flash
  fast:
    model: openai/gpt-5.6-luna
    reasoningEffort: medium


# ============================================================================
# Additional implementer variants
# ============================================================================
# Each entry creates a new agent `implementer-<suffix>` based on the implementer
# template, with a different model. Same gated execution protocol
# (blueprint → gate → execute → digest), different model choices.
#
# Supported options keys (routed to OpenCode provider options):
#   reasoningEffort: low | medium | high | xhigh
#   temperature: <float>
#   top_p: <float>
#   maxTokens: <int>
#
# The primary agent can then target a specific variant:
#   "use implementer-fast for this work package"

additional_implementers:
  strong:
    model: openai/gpt-5.6-sol
    reasoningEffort: xhigh
  fast:
    model: openai/gpt-5.6-luna
    reasoningEffort: medium
  safe:
    model: deepseek/deepseek-v4-pro
    reasoningEffort: high


# ============================================================================
# Alternative model examples (uncomment to use)
# ============================================================================
# delegate: alibaba-eu/qwen3.7-max
# doc-explorer: deepseek/deepseek-v4-pro
# implementer: deepseek/deepseek-v4-pro
